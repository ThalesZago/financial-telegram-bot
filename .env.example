# Copy this file to .env and fill in the values

# Neon PostgreSQL connection string
POSTGRES_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Optional: Secret token to validate Telegram webhook requests
# Set this when registering the webhook with Telegram using the secret_token parameter
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="your-openrouter-model" # e.g. "google/gemma-4-31b-it:free"

